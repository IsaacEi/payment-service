{
  "info": {
    "name": "Payment Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"concept\": \"Compra de productos\",\n  \"productQuantity\": 3,\n  \"payer\": \"Isaac Cisneros\",\n  \"payee\": \"Proveedor ABC\",\n  \"totalAmount\": 1500.75\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/payments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payments"
          ]
        }
      }
    },
    {
      "name": "Get Payment By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/payments/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payments",
            "1"
          ]
        }
      }
    },
    {
      "name": "Get Payment Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/payments/1/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payments",
            "1",
            "status"
          ]
        }
      }
    },
    {
      "name": "Update Payment Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"statusCode\": \"PAID\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/payments/1/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payments",
            "1",
            "status"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}